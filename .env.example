# Copy to .env and adjust as needed
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=wppass

WP_PORT=8080
WP_URL=http://localhost:8080
WP_ADMIN_USER=admin
WP_ADMIN_PASS=admin
WP_ADMIN_EMAIL=admin@example.com
WP_TITLE=EmbedPress E2E

# ── Plugin paths ────────────────────────────────────────────────────────────
# Absolute (or relative-to-repo-root) paths to your local plugin checkouts.
# Leave blank to fall back to the wordpress.org free version.
#
# Example:
#   EP_FREE_PLUGIN_PATH=../EmbedPress/embedpress
#   EP_PRO_PLUGIN_PATH=../EmbedPress/embedpress-pro
EP_FREE_PLUGIN_PATH=../EmbedPress/embedpress
EP_PRO_PLUGIN_PATH=../EmbedPress/embedpress-pro
