# Copy to .env and adjust as needed
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=wordpress
MYSQL_USER=wpuser
MYSQL_PASSWORD=wppass

WP_PORT=8080
WP_URL=http://localhost:8080
WP_ADMIN_USER=admin
WP_ADMIN_PASS=admin
WP_ADMIN_EMAIL=admin@example.com
WP_TITLE=EmbedPress E2E

# ── Plugin paths ────────────────────────────────────────────────────────────
# Absolute (or relative-to-repo-root) paths to your local plugin checkouts.
# Leave blank to fall back to the wordpress.org free version.
#
# Example:
#   EP_FREE_PLUGIN_PATH=../EmbedPress/embedpress
#   EP_PRO_PLUGIN_PATH=../EmbedPress/embedpress-pro
EP_FREE_PLUGIN_PATH=../EmbedPress/embedpress
EP_PRO_PLUGIN_PATH=../EmbedPress/embedpress-pro

# ── YouTube Data API key (optional) ─────────────────────────────────────────
# Required for sources whose render path hits the YouTube Data API:
#   - YouTube Channel  → fetches channel videos
#   - YouTube Live (Channel) when no live stream is currently active
# When unset, EmbedPress falls back to a "please enter your YouTube API key"
# placeholder and channel content does not render. Get a key from
# https://console.cloud.google.com/ → APIs & Services → Credentials.
# `setup-wp.sh` writes this into the `embedpress:youtube` option at install.
YT_SECRET=

# ── Slack reporter (optional) ───────────────────────────────────────────────
# When both are set, playwright-slack-report posts run results to Slack.
# Leave blank to disable. SLACK_BOT_TOKEN must be a bot token (xoxb-...) with
# chat:write scope on the target channel.
#   SLACK_SEND_RESULTS overrides when to post: always | on-failure | off (default: always)
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=
SLACK_SEND_RESULTS=always
